  "components": {
    "schemas": {
      "AddSkillRequest": {
        "required": [
          "proficiencyLevel",
          "skillId"
        ],
        "type": "object",
        "properties": {
          "skillId": {
            "type": "integer",
            "format": "int32"
          },
          "proficiencyLevel": {
            "minLength": 1,
            "pattern": "^(Beginner|Intermediate|Expert)$",
            "type": "string"
          }
        },
        "additionalProperties": false
      },
      "AdminDashboardStats": {
        "type": "object",
        "properties": {
          "totalUsers": {
            "type": "integer",
            "format": "int32"
          },
          "totalStudents": {
            "type": "integer",
            "format": "int32"
          },
          "totalRecruiters": {
            "type": "integer",
            "format": "int32"
          },
          "totalJobs": {
            "type": "integer",
            "format": "int32"
          },
          "activeJobs": {
            "type": "integer",
            "format": "int32"
          },
          "totalApplications": {
            "type": "integer",
            "format": "int32"
          },
          "appliedApplications": {
            "type": "integer",
            "format": "int32"
          },
          "shortlistedApplications": {
            "type": "integer",
            "format": "int32"
          },
          "rejectedApplications": {
            "type": "integer",
            "format": "int32"
          },
          "databaseType": {
            "type": "string",
            "nullable": true
          },
          "geminiStatus": {
            "type": "string",
            "nullable": true
          },
          "popularSkills": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/SkillStat"
            },
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "AdminUserListItem": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "nullable": true
          },
          "fullName": {
            "type": "string",
            "nullable": true
          },
          "email": {
            "type": "string",
            "nullable": true
          },
          "userType": {
            "type": "string",
            "nullable": true
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          },
          "isActive": {
            "type": "boolean"
          },
          "extraInfo": {
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "CreateJobRequest": {
        "required": [
          "description",
          "jobType",
          "location",
          "requirements",
          "title"
        ],
        "type": "object",
        "properties": {
          "title": {
            "minLength": 1,
            "type": "string"
          },
          "description": {
            "minLength": 1,
            "type": "string"
          },
          "requirements": {
            "minLength": 1,
            "type": "string"
          },
          "location": {
            "minLength": 1,
            "type": "string"
          },
          "salaryRange": {
            "type": "string",
            "nullable": true
          },
          "jobType": {
            "minLength": 1,
            "pattern": "^(Full-time|Part-time|Internship|Contract)$",
            "type": "string"
          }
        },
        "additionalProperties": false
      },
      "ForgotPasswordRequest": {
        "required": [
          "email"
        ],
        "type": "object",
        "properties": {
          "email": {
            "minLength": 1,
            "type": "string",
            "format": "email"
          }
        },
        "additionalProperties": false
      },
      "LoginRequest": {
        "required": [
          "email",
          "password"
        ],
        "type": "object",
        "properties": {
          "email": {
            "minLength": 1,
            "type": "string",
            "format": "email"
          },
          "password": {
            "minLength": 1,
            "type": "string"
          }
        },
        "additionalProperties": false
      },
      "RegisterRequest": {
        "required": [
          "email",
          "fullName",
          "password",
          "userType"
        ],
        "type": "object",
        "properties": {
          "email": {
            "minLength": 1,
            "type": "string",
            "format": "email"
          },
          "password": {
            "minLength": 6,
            "type": "string"
          },
          "fullName": {
            "minLength": 1,
            "type": "string"
          },
          "userType": {
            "minLength": 1,
            "pattern": "^(Student|Recruiter|Admin)$",
            "type": "string"
          }
        },
        "additionalProperties": false
      },
      "ResetPasswordRequest": {
        "required": [
          "code",
          "email",
          "newPassword"
        ],
        "type": "object",
        "properties": {
          "email": {
            "minLength": 1,
            "type": "string",
            "format": "email"
          },
          "code": {
            "minLength": 1,
            "type": "string"
          },
          "newPassword": {
            "minLength": 6,
            "type": "string"
          }
        },
        "additionalProperties": false
      },
      "SkillStat": {
        "type": "object",
        "properties": {
          "skillName": {
            "type": "string",
            "nullable": true
          },
          "count": {
            "type": "integer",
            "format": "int32"
          }
        },
        "additionalProperties": false
      },
      "UpdateApplicationStatusRequest": {
        "required": [
          "status"
        ],
        "type": "object",
        "properties": {
          "status": {
            "minLength": 1,
            "pattern": "^(Applied|Shortlisted|Rejected)$",
            "type": "string"
          },
          "feedback": {
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "UpdateRecruiterProfileRequest": {
        "required": [
          "companyName"
        ],
        "type": "object",
        "properties": {
          "companyName": {
            "minLength": 1,
            "type": "string"
          },
          "companyWebsite": {
            "type": "string",
            "nullable": true
          },
          "companyBio": {
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "UpdateStudentProfileRequest": {
        "required": [
          "targetJobTitle"
        ],
        "type": "object",
        "properties": {
          "bio": {
            "type": "string",
            "nullable": true
          },
          "educationDetails": {
            "type": "string",
            "nullable": true
          },
          "targetJobTitle": {
            "minLength": 1,
            "type": "string"
          },
          "linkedIn": {
            "type": "string",
            "nullable": true
          },
          "github": {
