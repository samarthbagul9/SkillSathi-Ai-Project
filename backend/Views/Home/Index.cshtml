@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>SkillSathi AI Platform - Unified Architecture</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;600;700&family=Plus+Jakarta+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
        :root {
            --bg-dark: #0a0b10;
            --bg-card: rgba(18, 20, 30, 0.65);
            --border-glow: rgba(154, 85, 241, 0.25);
            --primary: #9a55f1;
            --primary-glow: rgba(154, 85, 241, 0.15);
            --secondary: #00f2fe;
            --text-main: #ffffff;
            --text-secondary: #9ca3af;
        }

        body {
            background-color: var(--bg-dark);
            color: var(--text-main);
            font-family: 'Plus Jakarta Sans', sans-serif;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            overflow-x: hidden;
            position: relative;
        }

        /* Ambient Glow Backgrounds */
        body::before {
            content: '';
            position: absolute;
            width: 400px;
            height: 400px;
            background: radial-gradient(circle, rgba(154, 85, 241, 0.2) 0%, transparent 70%);
            top: 10%;
            left: 10%;
            z-index: 1;
        }

        body::after {
            content: '';
            position: absolute;
            width: 450px;
            height: 450px;
            background: radial-gradient(circle, rgba(0, 242, 254, 0.15) 0%, transparent 70%);
            bottom: 10%;
            right: 10%;
            z-index: 1;
        }

        .glass-card {
            background: var(--bg-card);
            backdrop-filter: blur(16px);
            border: 1px solid var(--border-glow);
            box-shadow: 0 8px 32px 0 rgba(0, 0, 0, 0.37);
            border-radius: 24px;
            padding: 40px;
            position: relative;
            z-index: 10;
            max-width: 750px;
            width: 100%;
        }

        .text-gradient-primary {
            background: linear-gradient(135deg, #ffffff 30%, var(--primary) 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        .text-gradient-secondary {
            background: linear-gradient(135deg, #ffffff 30%, var(--secondary) 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        .tech-badge {
            background: rgba(154, 85, 241, 0.12);
            color: var(--primary);
            border: 1px solid var(--border-glow);
            border-radius: 50px;
            padding: 6px 16px;
            font-size: 0.85rem;
            font-weight: 600;
            display: inline-block;
            margin-bottom: 20px;
        }

        .architecture-grid {
            margin-top: 30px;
        }

        .arch-box {
            background: rgba(255, 255, 255, 0.02);
            border: 1px solid rgba(255, 255, 255, 0.05);
            border-radius: 16px;
            padding: 24px;
            transition: all 0.3s ease;
        }

        .arch-box:hover {
            border-color: var(--border-glow);
            background: rgba(154, 85, 241, 0.04);
            transform: translateY(-2px);
        }

        .btn-premium {
            background: linear-gradient(135deg, var(--primary) 0%, #7c3aed 100%);
            color: white;
            border: none;
            border-radius: 12px;
            padding: 12px 30px;
            font-weight: 600;
            transition: all 0.3s ease;
            box-shadow: 0 4px 15px rgba(154, 85, 241, 0.4);
            text-decoration: none;
            display: inline-block;
        }

        .btn-premium:hover {
            opacity: 0.95;
            box-shadow: 0 6px 20px rgba(154, 85, 241, 0.6);
            color: white;
        }
    </style>
</head>
<body>

    <div class="glass-card text-center shadow-lg">
        <span class="tech-badge">ASP.NET Core 8.0</span>
        
        <h1 class="display-5 fw-bold mb-3 text-gradient-primary">Unified System Architecture</h1>
        <p class="text-secondary mx-auto mb-4" style="max-width: 600px;">
            The SkillSathi AI Platform backend has been updated to support both modern JSON-driven Web APIs and server-rendered MVC views.
        </p>

        <div class="row g-4 text-start architecture-grid">
            <div class="col-md-6">
                <div class="arch-box h-100">
                    <h3 class="h5 text-white mb-2">⚡ Web API Subsystem</h3>
                    <p class="text-secondary mb-3" style="font-size: 0.9rem;">
                        Powers the SPA (React/Vite) client, mock interview modules, and SignalR real-time chats with high-performance JSON endpoints.
                    </p>
                    <a href="/swagger" class="btn btn-sm btn-outline-info text-decoration-none">Swagger API Docs</a>
                </div>
            </div>
            <div class="col-md-6">
                <div class="arch-box h-100">
                    <h3 class="h5 text-white mb-2">🖥️ MVC Subsystem</h3>
                    <p class="text-secondary mb-3" style="font-size: 0.9rem;">
                        Allows traditional Razor view engines to dynamically compile and serve server-side HTML directly from the ASP.NET Core pipelines.
                    </p>
                    <span class="badge bg-secondary py-1 px-2" style="font-size: 0.75rem;">Active (Serving this view)</span>
                </div>
            </div>
        </div>

        <div class="mt-5">
            <a href="http://localhost:5173" class="btn-premium">Open React Portal</a>
        </div>
    </div>

</body>
</html>
